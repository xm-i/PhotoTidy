<Window
    x:Class="PhotoTidy.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PhotoTidy"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:PhotoTidy.ViewModels"
    xmlns:models="using:PhotoTidy.Models"
    xmlns:conv="using:PhotoTidy.Converters"
    mc:Ignorable="d"
    Title="PhotoTidy">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" RowSpacing="8" ColumnSpacing="8" Padding="12">
        <Grid.Resources>
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

		<!-- Folder input area -->
		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>
			<TextBox Grid.Column="0" x:Name="FolderTextBox" Width="500" Text="{x:Bind ViewModel.FolderPath.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="フォルダパスを入力 (Enter で読み込み)" KeyDown="FolderTextBox_KeyDown"/>
			<Button Grid.Column="1" Content="参照" Command="{x:Bind ViewModel.BrowseCommand}"/>
			<Button Grid.Column="2" Content="読み込み" Command="{x:Bind ViewModel.LoadCommand}"/>
			<CheckBox Grid.Column="3" Content="サブディレクトリを含む"
					  Margin="12,0,0,0" VerticalAlignment="Center"
					  IsChecked="{x:Bind ViewModel.IncludeSubdirectories.Value, Mode=TwoWay}"/>
			<TextBlock Grid.Column="4" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="Gray" Text="{x:Bind ViewModel.Status.Value}"/>
			<Button Grid.Column="5" Content="移動" Width="72" Command="{x:Bind ViewModel.MoveFilesCommand}" />
		</Grid>

		<!-- Tag definitions -->
		<ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
			<StackPanel Orientation="Horizontal" Spacing="6">
				<ItemsControl ItemsSource="{x:Bind ViewModel.Tags}">
					<ItemsControl.ItemsPanel>
						<ItemsPanelTemplate>
							<StackPanel Orientation="Horizontal" Spacing="6"/>
						</ItemsPanelTemplate>
					</ItemsControl.ItemsPanel>
					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="models:TagInfo">
							<Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
									CornerRadius="6" Padding="10,6" VerticalAlignment="Center">
								<StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
									<Border Background="{ThemeResource AccentFillColorDefaultBrush}"
											CornerRadius="4" Padding="6,2" MinWidth="28"
											VerticalAlignment="Center"
											Visibility="{Binding Key.Value, Converter={StaticResource NullToVisibilityConverter}}">
										<TextBlock Text="{x:Bind Key.Value, Mode=OneWay}"
												   Foreground="White" FontWeight="Bold" FontSize="12"
												   HorizontalAlignment="Center"/>
									</Border>
									<StackPanel Spacing="0" VerticalAlignment="Center">
										<TextBlock Text="{x:Bind Name.Value, Mode=OneWay}"
												   FontWeight="SemiBold" VerticalAlignment="Center" FontSize="13"/>
										<TextBlock Text="{x:Bind TargetFolder.Value, Mode=OneWay}"
												   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
												   FontSize="11" MaxWidth="220" TextTrimming="CharacterEllipsis"
												   Visibility="{Binding TargetFolder.Value, Converter={StaticResource NullToVisibilityConverter}}"/>
									</StackPanel>
									<Button Click="RemoveTag_Click"
											Background="Transparent" Padding="4,2"
											VerticalAlignment="Center" MinWidth="0" MinHeight="0">
										<FontIcon Glyph="&#xE711;" FontSize="10"/>
									</Button>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
				<Button Click="AddTagDefinition_Click" VerticalAlignment="Center"
						Padding="8,6" CornerRadius="6">
					<StackPanel Orientation="Horizontal" Spacing="4">
						<FontIcon Glyph="&#xE710;" FontSize="12"/>
						<TextBlock Text="追加" FontSize="12"/>
					</StackPanel>
				</Button>
			</StackPanel>
		</ScrollViewer>

        <GridView
            x:Name="ImagesGrid"
            Grid.Row="2"
            IsItemClickEnabled="True"
            SelectionMode="Single"
            ItemsSource="{x:Bind ViewModel.Images}"
            SelectedIndex="{x:Bind ViewModel.SelectedIndex.Value, Mode=TwoWay}">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid MaximumRowsOrColumns="0" Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="vm:ImageItemViewModel">
                    <StackPanel Width="160" Margin="4" DoubleTapped="ImageItem_DoubleTapped">
                        <Border CornerRadius="4" BorderBrush="#33000000" BorderThickness="1">
                            <Grid>
                                <Image Source="{x:Bind Thumbnail.Value, Mode=OneWay}" Stretch="UniformToFill" Width="160" Height="110" />
                                <Border x:Name="TagBadge" Background="#AA000000" Padding="4" HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="0,0,0,4">
                                    <TextBlock Text="{x:Bind Tag.Value,Mode=OneWay}" Foreground="White" FontSize="16"/>
                                </Border>
                            </Grid>
                        </Border>
                        <TextBlock TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" FontSize="12" Margin="0,4,0,0" Text="{x:Bind FileName.Value}" />
                    </StackPanel>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Window>
